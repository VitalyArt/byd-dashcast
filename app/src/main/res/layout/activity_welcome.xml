<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingLeft="40dp"
        android:paddingTop="32dp"
        android:paddingRight="40dp"
        android:paddingBottom="32dp">

    <!-- Logo / titre app -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/welcome_title"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/welcome_subtitle"
        android:textColor="#4A9FDF"
        android:textSize="14sp"
        android:letterSpacing="0.2"
        android:layout_marginBottom="32dp"/>

    <!-- Invite bilingue -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/welcome_select_lang"
        android:textColor="#888888"
        android:textSize="15sp"
        android:gravity="center"
        android:lineSpacingMultiplier="1.5"
        android:layout_marginBottom="24dp"/>

    <!-- French button -->
    <Button
        android:id="@+id/btn_lang_fr"
        android:layout_width="260dp"
        android:layout_height="52dp"
        android:text="@string/btn_lang_fr"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="#1A237E"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="10dp"/>

    <!-- Bouton English -->
    <Button
        android:id="@+id/btn_lang_en"
        android:layout_width="260dp"
        android:layout_height="52dp"
        android:text="@string/btn_lang_en"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="#1A237E"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="10dp"/>

    <!-- Bouton Deutsch -->
    <Button
        android:id="@+id/btn_lang_de"
        android:layout_width="260dp"
        android:layout_height="52dp"
        android:text="@string/btn_lang_de"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="#1A237E"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="10dp"/>

    <!-- Bouton Türkçe -->
    <Button
        android:id="@+id/btn_lang_tr"
        android:layout_width="260dp"
        android:layout_height="52dp"
        android:text="@string/btn_lang_tr"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="#1A237E"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="10dp"/>

    <!-- Bouton Italiano -->
    <Button
        android:id="@+id/btn_lang_it"
        android:layout_width="260dp"
        android:layout_height="52dp"
        android:text="@string/btn_lang_it"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="#1A237E"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="10dp"/>

    <!-- Bouton Русский -->
    <Button
        android:id="@+id/btn_lang_ru"
        android:layout_width="260dp"
        android:layout_height="52dp"
        android:text="@string/btn_lang_ru"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="#1A237E"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="10dp"/>

    <!-- Bouton Oʻzbekcha -->
    <Button
        android:id="@+id/btn_lang_uz"
        android:layout_width="260dp"
        android:layout_height="52dp"
        android:text="@string/btn_lang_uz"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="#1A237E"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="10dp"/>

    <!-- Bouton Қазақша -->
    <Button
        android:id="@+id/btn_lang_kk"
        android:layout_width="260dp"
        android:layout_height="52dp"
        android:text="@string/btn_lang_kk"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="#1A237E"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="10dp"/>

    <!-- Bouton Беларуская -->
    <Button
        android:id="@+id/btn_lang_be"
        android:layout_width="260dp"
        android:layout_height="52dp"
        android:text="@string/btn_lang_be"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="#1A237E"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="10dp"/>

    <!-- Bouton Українська -->
    <Button
        android:id="@+id/btn_lang_uk"
        android:layout_width="260dp"
        android:layout_height="52dp"
        android:text="@string/btn_lang_uk"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="#1A237E"
        android:textColor="#FFFFFF"/>

    </LinearLayout>

</ScrollView>
