<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Titre -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_title"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_subtitle"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:layout_marginBottom="20dp"/>

        <!-- ======================== TEST 1 — ADB LOCAL ======================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_test1_title"
            android:textColor="#A5D6A7"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_test1_desc"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_adb_local"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_adb_local_label"
            android:textSize="14sp"
            android:backgroundTint="#2E7D32"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_adb_local_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_press_hint"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:padding="12dp"
            android:background="#1A2A1A"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_adb_share"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_share_result1_btn"
            android:textSize="13sp"
            android:backgroundTint="#1565C0"
            android:layout_marginBottom="16dp"/>

        <!-- TEST 2 : Restauration cluster -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_test2_title"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_test2_desc"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_display1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_launch_test2_btn"
            android:textSize="15sp"
            android:backgroundTint="#E65100"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_display1_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_result_test2_hint"
            android:textColor="#CCCCCC"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:background="#1A1200"
            android:padding="8dp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_display1_share"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_share_result2_btn"
            android:textSize="13sp"
            android:backgroundTint="#1565C0"
            android:layout_marginBottom="16dp"/>

        <!-- ======================== TEST 3 — DISPLAY SIZE ======================== -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#444444"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_test3_title"
            android:textColor="#80DEEA"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_test3_desc"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <!-- Ligne 1 : 3 boutons taille -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn_display_size_88"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/diag_size_88_btn"
                android:textSize="12sp"
                android:backgroundTint="#00695C"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btn_display_size_123"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/diag_size_123_btn"
                android:textSize="12sp"
                android:backgroundTint="#1B5E20"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btn_display_size_1025"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/diag_size_1025_btn"
                android:textSize="12sp"
                android:backgroundTint="#00695C"
                android:layout_marginStart="4dp"/>

        </LinearLayout>

        <!-- Row 2: Restore -->
        <Button
            android:id="@+id/btn_display_size_restore"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_size_restore_btn"
            android:textSize="13sp"
            android:backgroundTint="#6A1B9A"
            android:layout_marginBottom="8dp"/>

        <!-- Ligne 3 : Diagnostic complet -->
        <Button
            android:id="@+id/btn_display_size_full"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_size_full_btn"
            android:textSize="13sp"
            android:backgroundTint="#00695C"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_display_size_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_test3_hint_text"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:padding="12dp"
            android:background="#111A1A"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_display_size_share"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_share_result3_btn"
            android:textSize="13sp"
            android:backgroundTint="#1565C0"
            android:layout_marginBottom="16dp"/>

        <!-- ======================== TEST 4 — BOOT RECEIVER ======================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_test4_title"
            android:textColor="#FFCC00"
            android:textStyle="bold"
            android:textSize="13sp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_test4_desc"
            android:textColor="#AAAAAA"
            android:textSize="11sp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_boot_receiver"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_launch_test4_btn"
            android:textSize="13sp"
            android:backgroundTint="#4A1580"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_boot_receiver_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_result_test4_hint"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:padding="12dp"
            android:background="#111A1A"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_boot_receiver_share"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_share_result4_btn"
            android:textSize="13sp"
            android:backgroundTint="#1565C0"
            android:layout_marginBottom="16dp"/>

    
        <!-- ======================== TEST 5 — GESTION MIRRORDAEMON ======================== -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#444444"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_test5_title"
            android:textColor="#FFAB40"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_test5_desc"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_scan_daemon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_scan_daemon_btn"
            android:textSize="13sp"
            android:backgroundTint="#1565C0"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_daemon_scan_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_scan_result_hint"
            android:textColor="#AAAAAA"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:padding="8dp"
            android:background="#1A1A1A"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_kill_daemon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_kill_daemon_btn"
            android:textSize="13sp"
            android:backgroundTint="#BF360C"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_kill_restart_daemon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_kill_restart_daemon_btn"
            android:textSize="13sp"
            android:backgroundTint="#E65100"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_export_daemon_log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_export_daemon_log_btn"
            android:textSize="13sp"
            android:backgroundTint="#6A1B9A"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_dump_sf_mirror"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_dump_sf_btn"
            android:textSize="13sp"
            android:backgroundTint="#00695C"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_sf_dump_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_dump_sf_result_hint"
            android:textColor="#AAAAAA"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:padding="8dp"
            android:background="#1A1A1A"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_clean_daemon_logs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_clean_daemon_btn"
            android:textSize="13sp"
            android:backgroundTint="#37474F"
            android:layout_marginBottom="16dp"/>

        <!-- ======================== TEST 6 — SYSTEM SNIFFER ======================== -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#444444"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_test6_title"
            android:textColor="#FFAB40"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_test6_desc"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_scan_sniffer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_scan_sniffer_btn"
            android:textSize="13sp"
            android:backgroundTint="#1565C0"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_sniffer_scan_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_sniffer_result_hint"
            android:textColor="#AAAAAA"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:padding="8dp"
            android:background="#1A1A1A"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_start_sniffer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_start_sniffer_btn"
            android:textSize="13sp"
            android:backgroundTint="#2E7D32"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_stop_sniffer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_stop_sniffer_btn"
            android:textSize="13sp"
            android:backgroundTint="#BF360C"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_export_sniffer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_export_sniffer_btn"
            android:textSize="13sp"
            android:backgroundTint="#1565C0"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_clean_sniffer_logs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_clean_sniffer_btn"
            android:textSize="13sp"
            android:backgroundTint="#37474F"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_test_daemon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_test_daemon_btn"
            android:textSize="13sp"
            android:backgroundTint="#d81b60"
            android:layout_marginBottom="16dp"/>

        <!-- ======================== TEST 7 — CLUSTER ORIENTATION ======================== -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#444444"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_test7_title"
            android:textColor="#FFAB40"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_test7_desc"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_orientation_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diag_orientation_hint"
            android:textColor="#AAAAAA"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:padding="8dp"
            android:background="#1A1A1A"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn_orient_freeze_landscape"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/diag_orient_freeze_landscape"
                android:textSize="11sp"
                android:backgroundTint="#1565C0"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btn_orient_freeze_portrait"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/diag_orient_freeze_portrait"
                android:textSize="11sp"
                android:backgroundTint="#BF360C"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btn_orient_unfreeze"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/diag_orient_unfreeze"
                android:textSize="11sp"
                android:backgroundTint="#2E7D32"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btn_orient_read"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/diag_orient_read"
                android:textSize="11sp"
                android:backgroundTint="#1565C0"
                android:layout_marginStart="4dp"/>

            <!-- TEST 13 JNI -->

            <TextView

                android:layout_width="match_parent"

                android:layout_height="wrap_content"

                android:text="TEST 13 — Vol de Surface JNI"

                android:textStyle="bold"

                android:layout_marginTop="16dp"

                android:textColor="#333"/>

            <TextView

                android:layout_width="match_parent"

                android:layout_height="wrap_content"

                android:text="Force BYD QtSurface native pointer extraction via libxdjacontainerservice_jni.so"

                android:textSize="12sp"

                android:layout_marginBottom="8dp"

                android:textColor="#666"/>

            <TextView

                android:id="@+id/tv_test_13_result"

                android:layout_width="match_parent"

                android:layout_height="wrap_content"

                android:text="--"

                android:textSize="12sp"

                android:fontFamily="monospace"

                android:background="#f5f5f5"

                android:padding="8dp"

                android:layout_marginBottom="8dp"/>

            <Button

                android:id="@+id/btn_test_13"

                android:layout_width="match_parent"

                android:layout_height="wrap_content"

                android:text="Execute getQtProjectionDispInfo(0)"

                android:backgroundTint="#FF9800"/>


        </LinearLayout>

</LinearLayout>
</ScrollView>
