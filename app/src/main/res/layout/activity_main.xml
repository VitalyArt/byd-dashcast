<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- ===== BARRE DE STATUT DASHBOARD ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#1A237E"
        android:padding="12dp">

        <TextView
            android:id="@+id/tv_dashboard_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/status_disconnected"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btn_activate_cluster"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/btn_activate_cluster"
            android:textSize="12sp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:backgroundTint="#1565C0"/>

        <Button
            android:id="@+id/btn_show_mirror"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/btn_show_mirror"
            android:textSize="12sp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:layout_marginStart="6dp"
            android:backgroundTint="#00695C"
            android:visibility="gone"/>

        <Button
            android:id="@+id/btn_restore_cluster"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/btn_restore_cluster"
            android:textSize="12sp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:layout_marginStart="6dp"
            android:backgroundTint="#B71C1C"/>

        <Button
            android:id="@+id/btn_origin_cluster"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/btn_origin_cluster"
            android:textSize="12sp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:layout_marginStart="6dp"
            android:backgroundTint="#2E7D32"/>

        <!-- ⋮ : access dev tools (Activate, Diag, Report, Language, Live log) -->
        <Button
            android:id="@+id/btn_overflow"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="⋮"
            android:textSize="18sp"
            android:padding="0dp"
            android:layout_marginStart="8dp"
            android:contentDescription="Options"/>
    </LinearLayout>

    <!-- ===== TITRE LISTE ===== -->
    <TextView
        android:id="@+id/tv_app_list_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/title_app_list"
        android:textSize="16sp"
        android:textStyle="bold"
        android:padding="12dp"
        android:background="#F5F5F5"/>

    <!-- ===== LISTE DES APPS ===== -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_apps"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="vertical"/>

    <!-- ===== MIROIR CLUSTER =====
         Wrapper FrameLayout contenant le SurfaceView miroir ET un placeholder texte.
         TextureView requires ACCESS_SURFACE_FLINGER (system permission):
         if unavailable, the placeholder is shown instead. -->
    <FrameLayout
        android:id="@+id/frame_cluster_mirror"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">

        <!-- TextureView: SF est le PRODUCTEUR (il rend le contenu du display dans la surface).
             new Surface(textureView.getSurfaceTexture()) = surface SF writes into → TextureView displays.
             SurfaceView.getSurface() was wrong: the app was the producer, not SF. -->
        <TextureView
            android:id="@+id/cluster_mirror"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Miroir cluster"/>

        <!-- Fallback screencap when SurfaceControl.createDisplay() fails (ROM permissions) -->
        <ImageView
            android:id="@+id/cluster_mirror_screenshot"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:background="#090C10"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Screenshot miroir cluster"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tv_mirror_placeholder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="@string/mirror_placeholder"
            android:textColor="#4A9FDF"
            android:textSize="18sp"
            android:background="#090C10"
            android:visibility="gone"/>

    </FrameLayout>

    <!-- ===== CLUSTER CONTROL PANEL =====
         Shown only when a third-party app is active on the cluster.
         Allows controlling the app from the main screen (cluster is non-touch). -->
    <LinearLayout
        android:id="@+id/panel_cluster_control"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0D1117"
        android:visibility="gone">

        <!-- Header: app name + hide button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"
            android:background="#161B22">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/cluster_control_title"
                android:textColor="#4A9FDF"
                android:textSize="12sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_control_app_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text=""
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1"/>

            <Button
                android:id="@+id/btn_cluster_split"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:text="@string/btn_cluster_split"
                android:textSize="10sp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:layout_marginEnd="6dp"
                android:backgroundTint="#5C6BC0"/>

            <Button
                android:id="@+id/btn_control_hide"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:text="@string/cluster_control_hide"
                android:textSize="10sp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"/>

            <Button
                android:id="@+id/btn_cluster_keyboard"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:text="@string/btn_cluster_keyboard"
                android:textSize="10sp"
                android:layout_marginStart="8dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
