 cd /home/ccarre/app_byd/MyBYDApp && cat << 'EOF' > mod.py
import re
with open('app/src/main/java/com/byd/myapp/DiagActivity.java', 'r') as f:
    text = f.read()

# Add eventCmd and inputCmd
fullCmd_old = """        String fullCmd = headerCmd
                + " && nohup sh -c \\"" + logcatCmd + "\\\" &"
                + " nohup sh -c \\"" + snapshotCmd + "\\\" &";"""

fullCmd_new = """        // ── Intent & Event Background Sniffing ────────────────────────────
        // Capture system events (notably sendInfo cmds sometimes passed as events)
        String eventCmd =
            "logcat -b events -v time | grep -iE 'byd|xdja|qt|cluster|sendinfo' >> " + p + " 2>/dev/null";

        // Capture input injection stats (touch on cluster)
        String inputCmd =
            "while true; do sleep 5;"
            + " dumpsys input 2>/dev/null | grep -iE 'FocusedWindow|TouchedWindow|byd|cluster' | head -5 >> " + p + ";"
            + " done";

        String fullCmd = headerCmd
                + " && nohup sh -c \\"" + logcatCmd + "\\\" &"
                + " nohup sh -c \\"" + snapshotCmd + "\\\" &"
                + " nohup sh -c \\"" + eventCmd + "\\\" &"
                + " nohup sh -c \\"" + inputCmd + "\\\" &";"""
text = text.replace(fullCmd_old, fullCmd_new)

# Modify snapshots
text = text.replace(" dumpsys display 2>/dev/null | grep -E 'mDisplayId|mState|fission|virtual' | head -10 ", " dumpsys display 2>/dev/null | grep -A 2 -B 2 -E 'mDisplayId|mState|fission|virtual|cluster|qt' | head -15 ")
text = text.replace(" dumpsys SurfaceFlinger 2>/dev/null | grep -iE 'display|fission|layer|cluster|mirror' | head -10 ", " dumpsys SurfaceFlinger 2>/dev/null | grep -iE 'display|fission|layer|cluster|mirror|qt' | head -15 ")
text = text.replace(" ps -A 2>/dev/null | grep -iE 'byd|xdja|freedom|daemon|mirror' >> " + p + ";", " dumpsys activity broadcasts history 2>/dev/null | grep -iE 'byd|xdja|freedom|sendinfo|qt' | head -20 >> " + p + ";" + "\\n" + "            + \" ps -A 2>/dev/null | grep -iE 'byd|xdja|freedom|daemon|mirror' | wc -l | sed \\"s/^/[Process count]: /\\" >> " + p + ";")

# Modify Header tags
text = text.replace(" WindowManager:V ActivityManager:V SurfaceFlinger:V\\"\\n            + \\" AutoContainer:V MirrorDaemon:V\\"\\n            + \\" byd:V xdja:V freedom:V cluster:V\\"", " WindowManager:V ActivityManager:V SurfaceFlinger:V\\"\\n            + \\" AutoContainer:V MirrorDaemon:V\\"\\n            + \\" byd:V xdja:V freedom:V cluster:V dilink:V diag:V qt:V container:V input:V BYD_*:V Qt*:V\\"")

text = text.replace(" echo '=== BYD SNIFFER DUMP ===' > ", " echo '=========================================' > \" + p\\n            + \" && echo '===  BYD SNIFFER DUMP (ENHANCED)  ===' >> \" + p\\n            + \" && echo '=========================================' >> ")

text = text.replace(" getprop ro.build.version.release >> \" + p\\n            + \" && echo '' >> \" + p\\n            + \" && echo '--- PROCESSUS BYD/XDJA/DAEMON ---'", " getprop ro.build.version.release >> \" + p\\n            + \" && getprop ro.product.model >> \" + p\\n            + \" && echo '' >> \" + p\\n            + \" && echo '--- BYD ENVIRONMENT ---' >> \" + p\\n            + \" && getprop | grep -i byd >> \" + p\\n            + \" && echo '' >> \" + p\\n            + \" && echo '--- PROCESSUS BYD/XDJA/DAEMON ---'")

with open('app/src/main/java/com/byd/myapp/DiagActivity.java', 'w') as f:
    f.write(text)
print("done")
EOF
